            "description": "Заказ или склад не найдены",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiNotFoundErrorBodyDto"
                }
              }
            }
          },
          "409": {
            "description": "Недопустимый переход или нарушение инварианта склада",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Отменить ещё не отгруженный заказ и снять резерв",
        "tags": [
          "orders"
        ]
      }
    },
