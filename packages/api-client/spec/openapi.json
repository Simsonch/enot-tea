  "info": {
    "title": "API Enot Tea",
    "description": "HTTP API для MVP: проверка работоспособности, каталог товаров и жизненный цикл заказа.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Локальная разработка"
    }
  ],
  "components": {
    "schemas": {
      "HealthDbResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Проверка жизнеспособности"
          },
          "db": {
            "type": "string",
            "example": "up",
            "description": "База данных"
          }
        },
        "required": [
          "status",
          "db"
        ]
      },
      "ProductListItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "priceMinor": {
            "type": "number",
            "example": 1000,
            "description": "Цена в минорных единицах"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "sku",
          "name",
          "priceMinor",
          "isActive"
        ]
      },
      "ProductPaginationDto": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "offset": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "limit",
          "offset",
          "total"
        ]
      },
      "ProductsListResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductListItemDto"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/ProductPaginationDto"
          }
        },
        "required": [
          "items",
          "pagination"
        ]
      },
      "OrderStatus": {
        "type": "string",
        "enum": [
          "NEW",
          "CONFIRMED",
          "PACKED",
          "SHIPPED",
          "DELIVERED",
          "CANCELLED"
        ]
      },
      "PaymentStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "INVOICE_SENT",
          "PAID",
          "REFUNDED",
          "PAYMENT_FAILED"
        ]
      },
      "FulfillmentStatus": {
        "type": "string",
        "enum": [
          "RESERVED",
          "HANDED_TO_CARRIER",
          "DELIVERED",
          "RETURNED"
        ]
      },
      "OrderItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "priceMinor": {
            "type": "number"
          },
          "totalMinor": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "productId",
          "quantity",
          "priceMinor",
          "totalMinor"
        ]
      },
      "OrderStatusDimension": {
        "type": "string",
        "enum": [
          "ORDER",
          "PAYMENT",
          "FULFILLMENT"
        ]
      },
      "OrderStatusHistoryEntryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "statusDimension": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatusDimension"
              }
            ]
          },
          "fromStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "toStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "fromPaymentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "toPaymentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "fromFulfillmentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "toFulfillmentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "changedById": {
            "type": "string",
            "nullable": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "statusDimension",
          "fromStatus",
          "toStatus",
          "fromPaymentStatus",
          "toPaymentStatus",
          "fromFulfillmentStatus",
          "toFulfillmentStatus",
          "changedById",
          "comment",
          "createdAt"
        ]
      },
      "OrderResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "customerId": {
            "type": "string",
            "nullable": true,
            "description": "Связанный id покупателя; null для гостевых заказов."
          },
          "customerFullName": {
            "type": "string"
          },
          "customerEmail": {
            "type": "string",
            "format": "email"
          },
          "customerPhone": {
            "type": "string",
            "nullable": true
          },
          "shippingAddress": {
            "type": "string"
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "paymentStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "fulfillmentStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "totalMinor": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemResponseDto"
            }
          },
          "statusHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderStatusHistoryEntryDto"
            }
          }
        },
        "required": [
          "id",
          "customerId",
          "customerFullName",
          "customerEmail",
          "customerPhone",
          "shippingAddress",
          "status",
          "paymentStatus",
          "fulfillmentStatus",
          "totalMinor",
          "createdAt",
          "updatedAt",
          "items",
          "statusHistory"
        ]
      },
      "ApiNotFoundErrorBodyDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 404
          },
          "message": {
            "type": "string",
            "example": "Заказ orderId=order-1 не найден."
          },
          "error": {
            "type": "string",
            "example": "Не найдено"
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "CreateOrderItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "description": "Идентификатор товара из публичного каталога."
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "example": 1
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Необязательный связанный id покупателя для негостевых заказов; для гостевого checkout не указывайте."
          },
          "customerFullName": {
            "type": "string",
            "example": "Иван Иванов",
            "description": "Снимок ФИО гостя/покупателя, хранимый в заказе."
          },
          "customerEmail": {
            "type": "string",
            "format": "email",
            "example": "customer@example.com",
            "description": "Снимок email гостя/покупателя, хранимый в заказе."
          },
          "customerPhone": {
            "type": "string",
            "example": "+995 555 010 010",
            "description": "Необязательный снимок телефона."
          },
          "shippingAddress": {
            "type": "string",
            "example": "Тбилиси, ул. Руставели, 1",
            "description": "Снимок адреса доставки, хранимый в заказе."
          },
          "items": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemDto"
            }
          }
        },
        "required": [
          "customerFullName",
          "customerEmail",
          "shippingAddress",
          "items"
        ]
      },
      "ValidationErrorField": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "example": "toStatus"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "field",
          "messages"
        ]
      },
      "ApiValidationErrorBodyDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationErrorField"
            }
          }
        },
        "required": [
          "statusCode",
          "code",
          "message"
        ]
      },
      "ApiBusinessConflictBodyDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 409
          },
          "code": {
            "type": "string",
            "example": "INVALID_ORDER_STATUS_TRANSITION",
            "description": "Один из: INSUFFICIENT_STOCK, PRODUCT_INACTIVE, INVALID_ORDER_STATUS_TRANSITION, INVENTORY_INVARIANT_VIOLATION"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "statusCode",
          "code",
          "message"
        ]
      },
      "ManualOrderLifecycleTransitionDto": {
        "type": "object",
        "properties": {
          "comment": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "UpdateOrderStatusDto": {
        "type": "object",
        "properties": {
          "toStatus": {
            "type": "string",
            "enum": [
              "CONFIRMED",
              "PACKED",
              "SHIPPED",
              "DELIVERED"
            ],
            "description": "Целевой статус; CANCELLED недопустим (используйте /cancel)."
          },
          "comment": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "toStatus"
        ]
      }
    }
  }
}
