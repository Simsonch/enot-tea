generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  CONSULTANT
  CUSTOMER
}

enum OrderStatus {
  NEW
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  INVOICE_SENT
  PAID
  REFUNDED
  PAYMENT_FAILED
}

enum FulfillmentStatus {
  RESERVED
  HANDED_TO_CARRIER
  DELIVERED
  RETURNED
}

enum OrderStatusDimension {
  ORDER
  PAYMENT
  FULFILLMENT
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  firstName            String?
  lastName             String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  changedOrderStatuses OrderStatusHistory[] @relation("OrderStatusChangedBy")
  roles                UserRole[]
  orders               Order[]              @relation("OrderCustomer")
  consultantChats      ChatSession[]        @relation("ChatConsultant")
  customerChats        ChatSession[]        @relation("ChatCustomer")
  chatMessages         ChatMessage[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  priceMinor  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryItem InventoryItem?
  orderItems    OrderItem[]
}

model InventoryItem {
  id        String   @id @default(cuid())
  productId String   @unique
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  movements StockMovement[]
}

model StockMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  orderId         String?
  orderItemId     String?
  deltaOnHand     Int      @default(0)
  deltaReserved   Int      @default(0)
  reason          String
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem     OrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, createdAt])
  @@index([orderId, createdAt])
  @@index([orderItemId, createdAt])
}

model Order {
  id                String            @id @default(cuid())
  customerId        String?
  customerFullName  String
  customerEmail     String
  customerPhone     String?
  shippingAddress   String
  status            OrderStatus       @default(NEW)
  paymentStatus     PaymentStatus     @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(RESERVED)
  totalMinor        Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  customer       User?                @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  stockMovements StockMovement[]
  notifications  NotificationAttempt[]

  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([fulfillmentStatus, createdAt])
  @@index([customerEmail, createdAt])
  @@index([customerId, createdAt])
}

model NotificationAttempt {
  id           String   @id @default(cuid())
  orderId      String
  event        String
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([orderId, status, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  priceMinor Int
  totalMinor Int
  createdAt  DateTime @default(now())

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id                    String               @id @default(cuid())
  orderId               String
  statusDimension       OrderStatusDimension @default(ORDER)
  fromStatus            OrderStatus?
  toStatus              OrderStatus?
  fromPaymentStatus     PaymentStatus?
  toPaymentStatus       PaymentStatus?
  fromFulfillmentStatus FulfillmentStatus?
  toFulfillmentStatus   FulfillmentStatus?
  changedById           String?
  comment               String?
  createdAt             DateTime             @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("OrderStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([orderId, statusDimension, createdAt])
}

model ChatSession {
  id           String    @id @default(cuid())
  customerId   String
  consultantId String?
  createdAt    DateTime  @default(now())
  closedAt     DateTime?

  customer   User          @relation("ChatCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  consultant User?         @relation("ChatConsultant", fields: [consultantId], references: [id], onDelete: SetNull)
  messages   ChatMessage[]

  @@index([customerId, createdAt])
  @@index([consultantId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User        @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([sessionId, createdAt])
}
