{
  "openapi": "3.0.0",
  "paths": {
    "/health/db": {
      "get": {
        "operationId": "HealthController_db",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthDbResponseDto"
                }
              }
            }
          }
        },
        "summary": "Database connectivity",
        "tags": [
          "health"
        ]
      }
    },
    "/products": {
      "get": {
        "operationId": "ProductsController_list",
        "parameters": [
          {
            "name": "isActive",
            "required": false,
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "offset",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductsListResponseDto"
                }
              }
            }
          }
        },
        "summary": "List products with pagination",
        "tags": [
          "products"
        ]
      }
    },
    "/orders/{id}": {
      "get": {
        "operationId": "OrdersController_getById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          }
        },
        "summary": "Get order with items and status history",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders": {
      "post": {
        "operationId": "OrdersController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Customer, product, or inventory row not found"
          },
          "409": {
            "description": "Out of stock or inactive product",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Create order and reserve stock",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/cancel": {
      "patch": {
        "operationId": "OrdersController_cancel",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualOrderLifecycleTransitionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order or inventory not found"
          },
          "409": {
            "description": "Invalid transition or inventory invariant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Cancel order",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/invoice-sent": {
      "patch": {
        "operationId": "OrdersController_markInvoiceSent",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualOrderLifecycleTransitionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          },
          "409": {
            "description": "Invalid lifecycle transition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Mark manual invoice as sent",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/payment-confirmed": {
      "patch": {
        "operationId": "OrdersController_confirmPayment",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualOrderLifecycleTransitionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          },
          "409": {
            "description": "Invalid lifecycle transition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Confirm manual payment",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/handoff-to-delivery": {
      "patch": {
        "operationId": "OrdersController_handOffToDelivery",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualOrderLifecycleTransitionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order or inventory not found"
          },
          "409": {
            "description": "Invalid transition or inventory invariant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Hand order off to delivery and ship reserved stock",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/delivered": {
      "patch": {
        "operationId": "OrdersController_confirmDelivered",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualOrderLifecycleTransitionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          },
          "409": {
            "description": "Invalid lifecycle transition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Confirm customer receipt / delivery",
        "tags": [
          "orders"
        ]
      }
    },
    "/orders/{id}/status": {
      "patch": {
        "operationId": "OrdersController_updateStatus",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Order id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrderStatusDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiValidationErrorBodyDto"
                }
              }
            }
          },
          "404": {
            "description": "Order or inventory not found"
          },
          "409": {
            "description": "Invalid transition or inventory invariant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiBusinessConflictBodyDto"
                }
              }
            }
          }
        },
        "summary": "Update order status",
        "tags": [
          "orders"
        ]
      }
    }
  },
  "info": {
    "title": "Enot Tea API",
    "description": "MVP HTTP API: health, product catalog, and order lifecycle.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "components": {
    "schemas": {
      "HealthDbResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Liveness"
          },
          "db": {
            "type": "string",
            "example": "up",
            "description": "Database"
          }
        },
        "required": [
          "status",
          "db"
        ]
      },
      "ProductListItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "priceMinor": {
            "type": "number",
            "example": 1000,
            "description": "Price in minor units"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "sku",
          "name",
          "priceMinor",
          "isActive"
        ]
      },
      "ProductPaginationDto": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "offset": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "limit",
          "offset",
          "total"
        ]
      },
      "ProductsListResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductListItemDto"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/ProductPaginationDto"
          }
        },
        "required": [
          "items",
          "pagination"
        ]
      },
      "OrderStatus": {
        "type": "string",
        "enum": [
          "NEW",
          "CONFIRMED",
          "PACKED",
          "SHIPPED",
          "DELIVERED",
          "CANCELLED"
        ]
      },
      "PaymentStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "INVOICE_SENT",
          "PAID",
          "REFUNDED",
          "PAYMENT_FAILED"
        ]
      },
      "FulfillmentStatus": {
        "type": "string",
        "enum": [
          "RESERVED",
          "HANDED_TO_CARRIER",
          "DELIVERED",
          "RETURNED"
        ]
      },
      "OrderItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "priceMinor": {
            "type": "number"
          },
          "totalMinor": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "productId",
          "quantity",
          "priceMinor",
          "totalMinor"
        ]
      },
      "OrderStatusDimension": {
        "type": "string",
        "enum": [
          "ORDER",
          "PAYMENT",
          "FULFILLMENT"
        ]
      },
      "OrderStatusHistoryEntryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "statusDimension": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatusDimension"
              }
            ]
          },
          "fromStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "toStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "fromPaymentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "toPaymentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "fromFulfillmentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "toFulfillmentStatus": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "changedById": {
            "type": "string",
            "nullable": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "statusDimension",
          "createdAt"
        ]
      },
      "OrderResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "customerId": {
            "type": "string",
            "nullable": true
          },
          "customerFullName": {
            "type": "string"
          },
          "customerEmail": {
            "type": "string",
            "format": "email"
          },
          "customerPhone": {
            "type": "string",
            "nullable": true
          },
          "shippingAddress": {
            "type": "string"
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderStatus"
              }
            ]
          },
          "paymentStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PaymentStatus"
              }
            ]
          },
          "fulfillmentStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/FulfillmentStatus"
              }
            ]
          },
          "totalMinor": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemResponseDto"
            }
          },
          "statusHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderStatusHistoryEntryDto"
            }
          }
        },
        "required": [
          "id",
          "customerFullName",
          "customerEmail",
          "shippingAddress",
          "status",
          "paymentStatus",
          "fulfillmentStatus",
          "totalMinor",
          "createdAt",
          "updatedAt",
          "items"
        ]
      },
      "CreateOrderItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "example": 1
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Linked customer id for non-guest orders."
          },
          "customerFullName": {
            "type": "string",
            "example": "Иван Иванов"
          },
          "customerEmail": {
            "type": "string",
            "format": "email",
            "example": "customer@example.com"
          },
          "customerPhone": {
            "type": "string",
            "example": "+995 555 010 010"
          },
          "shippingAddress": {
            "type": "string",
            "example": "Тбилиси, ул. Руставели, 1"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemDto"
            }
          }
        },
        "required": [
          "customerFullName",
          "customerEmail",
          "shippingAddress",
          "items"
        ]
      },
      "ValidationErrorField": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "example": "toStatus"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "field",
          "messages"
        ]
      },
      "ApiValidationErrorBodyDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationErrorField"
            }
          }
        },
        "required": [
          "statusCode",
          "code",
          "message"
        ]
      },
      "ApiBusinessConflictBodyDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 409
          },
          "code": {
            "type": "string",
            "example": "INVALID_ORDER_STATUS_TRANSITION",
            "description": "One of: INSUFFICIENT_STOCK, PRODUCT_INACTIVE, INVALID_ORDER_STATUS_TRANSITION, INVENTORY_INVARIANT_VIOLATION"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "statusCode",
          "code",
          "message"
        ]
      },
      "ManualOrderLifecycleTransitionDto": {
        "type": "object",
        "properties": {
          "comment": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "UpdateOrderStatusDto": {
        "type": "object",
        "properties": {
          "toStatus": {
            "type": "string",
            "enum": [
              "CONFIRMED",
              "PACKED",
              "SHIPPED",
              "DELIVERED"
            ],
            "description": "Target status; CANCELLED is not allowed (use /cancel)."
          },
          "comment": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "toStatus"
        ]
      }
    }
  }
}
